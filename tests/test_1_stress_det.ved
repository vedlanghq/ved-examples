domain NodeOne {
    scope { domain }
    capability { messaging, send_to:NodeTwo }
    state { actual: int target_val: int }
    goal Sync { priority 100 target actual == target_val strategy { Ping } }
    transition Boot { capability { messaging, send_to:NodeTwo } slice step { target_val = 333333 } }
    transition Ping { capability { messaging, send_to:NodeTwo } slice step { actual = actual + 1 send("NodeTwo", "Pong") } }
    transition Pong { capability { messaging, send_to:NodeTwo } slice step { actual = actual + 1 } }
}

